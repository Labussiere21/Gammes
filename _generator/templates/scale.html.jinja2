<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ ui_title }}</title>
  <meta name="description" content="{{ ui_meta_desc }}">
  <link rel="canonical" href="{{ page_url }}">
  <link rel="alternate" hreflang="fr" href="{{ alt_url_fr }}">
  <link rel="alternate" hreflang="en" href="{{ alt_url_en }}">
  <link rel="alternate" hreflang="x-default" href="{{ alt_url_fr }}">
  <meta property="og:title" content="{{ ui_og_title }}">
  <meta property="og:description" content="{{ ui_og_desc }}">
  <meta property="og:type" content="article">
  <meta property="og:url" content="{{ page_url }}">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ ui_schema_head }}",
    "description": "{{ ui_schema_desc }}",
    "url": "{{ page_url }}",
    "publisher": { "@type": "Organization", "name": "ScalaBass" }
  }
  </script>
  <style>
    :root{--bg:#1a1a20;--panel:#23232b;--line:#333340;--text:#e8e8f0;--muted:#8888a0;--brass:#c8a840;--green:#60c8a0;--blue:#45a3d9;--red:#e8503a}
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:var(--bg);color:var(--text);font-family:"Segoe UI",system-ui,sans-serif;font-size:15px;line-height:1.6;min-height:100vh}
    a{color:var(--brass);text-decoration:none}
    a:hover{text-decoration:underline}

    .topnav{background:var(--panel);border-bottom:1px solid var(--line);padding:10px 20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap}
    .topnav .logo{font-weight:700;letter-spacing:.15em;font-size:13px;text-transform:uppercase;color:var(--brass)}
    .topnav a{color:var(--muted);font-size:13px}
    .topnav a:hover{color:var(--text)}

    .breadcrumb{padding:10px 24px;font-size:12px;color:var(--muted)}
    .breadcrumb a{color:var(--muted)}

    main{max-width:860px;margin:0 auto;padding:28px 24px 64px}

    h1{font-size:clamp(22px,4vw,34px);font-weight:700;line-height:1.2;margin-bottom:6px}
    .sub{color:var(--muted);font-size:14px;margin-bottom:28px}

    h2{font-size:16px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin:32px 0 12px;border-bottom:1px solid var(--line);padding-bottom:6px}

    .notes-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px}
    .note-pill{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:8px 14px;font-family:"Space Mono",monospace;font-size:15px;font-weight:700;color:var(--brass)}
    .note-pill.root{border-color:var(--brass);background:var(--brass)18;color:var(--brass)}

    .iv-row{display:flex;flex-wrap:wrap;align-items:center;gap:6px;font-family:"Space Mono",monospace;font-size:13px}
    .iv-note{background:var(--panel);border:1px solid var(--line);border-radius:6px;padding:4px 10px;color:var(--text)}
    .iv-sep{color:var(--muted);font-size:11px;padding:0 2px}
    .iv-label{color:var(--green);background:var(--green)15;border:1px solid var(--green)44;border-radius:5px;padding:2px 7px;font-size:11px}
    .iv-label.ht{color:var(--red);background:var(--red)12;border-color:var(--red)44}
    .iv-label.aug{color:var(--blue);background:var(--blue)12;border-color:var(--blue)44}

    .triad-table{width:100%;border-collapse:collapse;font-size:14px}
    .triad-table th{text-align:left;padding:6px 10px;color:var(--muted);font-weight:600;border-bottom:1px solid var(--line)}
    .triad-table td{padding:7px 10px;border-bottom:1px solid var(--line)88}
    .triad-table tr:last-child td{border-bottom:none}
    .roman{font-family:"Space Mono",monospace;font-weight:700;color:var(--brass)}
    .q-maj{color:var(--green)}
    .q-min{color:var(--blue)}
    .q-dim{color:var(--red)}
    .q-aug{color:#f08a3c}

    .desc-block{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:18px 20px;line-height:1.7;color:#c8c8d8;font-size:14px}

    .cta-block{margin-top:40px;background:var(--panel);border:1px solid var(--brass)44;border-radius:12px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
    .cta-block p{font-size:14px;color:var(--muted);max-width:420px}
    .cta-btn{display:inline-block;background:var(--brass);color:#1a1a20;font-weight:700;font-size:14px;padding:10px 22px;border-radius:8px;text-decoration:none;white-space:nowrap}
    .cta-btn:hover{background:#e0b840;text-decoration:none}

    .page-nav{margin-top:48px;padding-top:24px;border-top:1px solid var(--line);display:flex;flex-wrap:wrap;gap:8px}
    .page-nav a{background:var(--panel);border:1px solid var(--line);border-radius:6px;padding:5px 12px;font-size:13px;color:var(--muted)}
    .page-nav a:hover{color:var(--text);text-decoration:none}
    .page-nav .active{border-color:var(--brass)55;color:var(--brass)}
  </style>
</head>
<body>

<nav class="topnav">
  <span class="logo">ScalaBass</span>
  <a href="{{ BASE_URL }}/">Manche</a>
  <a href="{{ BASE_URL }}/gammes.html">Gammes</a>
  <a href="{{ BASE_URL }}/intervalles.html">Intervalles</a>
  <a href="{{ BASE_URL }}/cadences.html">Cadences</a>
  <a href="{{ BASE_URL }}/arpeges-basse.html">Arpèges</a>
</nav>

<div class="breadcrumb">
  <a href="{{ nav_base }}/">{{ ui_all_scales }}</a>
  {% if lang == 'fr' %}
  &rsaquo; {{ root.fr }}
  {% else %}
  &rsaquo; {{ root.name }}
  {% endif %}
  &rsaquo; {{ label }}
</div>

<main>
  <h1>{{ ui_h1 }}</h1>
  <p class="sub">
    {{ ui_bass }}
    {%- if sub %} &nbsp;·&nbsp; {{ sub }}{% endif %}
    &nbsp;·&nbsp; {{ n_notes }} note{{ 's' if n_notes > 1 else '' }}
    &nbsp;·&nbsp; {{ ui_family }}
  </p>

  <h2>{{ ui_notes }}</h2>
  <div class="notes-row">
    {% for note in notes_primary %}
    <div class="note-pill{% if loop.first %} root{% endif %}">{{ note }}</div>
    {% endfor %}
  </div>
  <p style="font-size:12px;color:var(--muted);margin-top:6px">
    {{ notes_secondary_label }} : {{ notes_secondary | join(' – ') }}
  </p>

  <h2>{{ ui_ivstruct }}</h2>
  <div class="iv-row">
    {% for note in notes_primary %}
    <span class="iv-note">{{ note }}</span>
    {% if not loop.last %}
    {% set nxt_iv = scale.iv[loop.index] - scale.iv[loop.index0] %}
    {% set diff = (nxt_iv + 12) % 12 %}
    {% if diff == 1 %}
      <span class="iv-label ht">½T</span>
    {% elif diff == 2 %}
      <span class="iv-label">T</span>
    {% elif diff == 3 %}
      <span class="iv-label aug">T+½T</span>
    {% else %}
      <span class="iv-label aug">{{ diff }}×½T</span>
    {% endif %}
    {% endif %}
    {% endfor %}
    <span class="iv-sep">→</span>
    <span class="iv-note">{{ notes_primary[0] }}+oct.</span>
    {% set last_diff = (12 - scale.iv[-1] + 12) % 12 %}
    {% if last_diff == 1 %}
      <span class="iv-label ht">½T</span>
    {% elif last_diff == 2 %}
      <span class="iv-label">T</span>
    {% elif last_diff == 3 %}
      <span class="iv-label aug">T+½T</span>
    {% else %}
      <span class="iv-label aug">{{ last_diff }}×½T</span>
    {% endif %}
  </div>

  {% if triads %}
  <h2>{{ ui_triads_title }}</h2>
  <table class="triad-table">
    <thead>
      <tr><th>{{ ui_degree }}</th><th>{{ ui_chord }}</th><th>{{ ui_quality }}</th></tr>
    </thead>
    <tbody>
      {% for t in triads %}
      <tr>
        <td class="roman">{{ t.roman }}</td>
        <td><strong>{{ t.name }}</strong></td>
        <td class="{% if t.quality in ['Majeur','Major'] %}q-maj{% elif t.quality in ['mineur','minor'] %}q-min{% elif t.quality in ['diminué','diminished'] %}q-dim{% elif t.quality in ['augmenté','augmented'] %}q-aug{% endif %}">{{ t.quality }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <h2>{{ ui_about }}</h2>
  <div class="desc-block">{{ desc }}</div>

  <div class="cta-block">
    <p>{{ ui_cta_text | safe }}</p>
    <a class="cta-btn" href="{{ app_link }}">{{ ui_cta_btn }}</a>
  </div>

  <h2 style="margin-top:40px">{{ ui_other_keys }}</h2>
  <div class="page-nav">
    {% for r in nav_roots %}
    <a href="{{ nav_base }}/{{ r.slug }}/{{ scale_slug }}/{% if r.slug == (root.slug if lang == 'fr' else root.slug_en) %}#{% endif %}"
       {% if r.slug == (root.slug if lang == 'fr' else root.slug_en) %}class="active"{% endif %}>{{ r.name }}</a>
    {% endfor %}
  </div>

</main>
</body>
</html>
